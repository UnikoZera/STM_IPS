namespace lcd_host
{
    public partial class MainWindow : Window
    {
        private const int LcdWidth = 160;
        private const int LcdHeight = 80;
        private const int FramePixels = LcdWidth * LcdHeight;
        private const int FrameBytes = FramePixels * 2;
        private const int TailBytes = 4;
        private const int FrameTotal = FrameBytes + TailBytes;
        private const int StreamCapacity = 256 * 1024;
        private static readonly byte[] FrameTail = [0x0D, 0x00, 0x07, 0x21];

        private readonly ObservableCollection<SerialPortInfo> _ports = [];
        private readonly List<byte> _lcdStream = [];
        private readonly object _lcdStreamLock = new();
        private SerialPort? _serialPort;
        private WriteableBitmap? _lcdBitmap;
        private ulong _lcdFrameIndex;
        private string? _selectedFilePath;

        private ComboBox PortComboBoxCtl => (ComboBox)FindName("PortComboBox")!;
        private ComboBox BaudRateComboBoxCtl => (ComboBox)FindName("BaudRateComboBox")!;
        private ComboBox ReceiveModeComboBoxCtl => (ComboBox)FindName("ReceiveModeComboBox")!;
        private ComboBox SendModeComboBoxCtl => (ComboBox)FindName("SendModeComboBox")!;
        private TextBox ReceiveTextBoxCtl => (TextBox)FindName("ReceiveTextBox")!;
        private TextBox SendTextBoxCtl => (TextBox)FindName("SendTextBox")!;
        private TextBox SelectedFileTextBoxCtl => (TextBox)FindName("SelectedFileTextBox")!;
        private CheckBox AppendNewLineCheckBoxCtl => (CheckBox)FindName("AppendNewLineCheckBox")!;
        private CheckBox EnableLcdDecodeCheckBoxCtl => (CheckBox)FindName("EnableLcdDecodeCheckBox")!;
        private Button OpenButtonCtl => (Button)FindName("OpenButton")!;
        private Button CloseButtonCtl => (Button)FindName("CloseButton")!;
        private Button RefreshButtonCtl => (Button)FindName("RefreshButton")!;
        private TextBlock StatusTextBlockCtl => (TextBlock)FindName("StatusTextBlock")!;
        private TextBlock LcdFrameInfoTextBlockCtl => (TextBlock)FindName("LcdFrameInfoTextBlock")!;
        private Image LcdPreviewImageCtl => (Image)FindName("LcdPreviewImage")!;

        public MainWindow()
        {
            InitializeComponent();
            PortComboBoxCtl.ItemsSource = _ports;
            InitBaudRates();
            InitLcdPreview();
            UpdateUiByConnectionState(false);
        }

        private void Window_Loaded(object sender, RoutedEventArgs e)
        {
            RefreshPorts();
            UpdateSelectedFilePath(null);
        }

        private void Window_Closing(object? sender, System.ComponentModel.CancelEventArgs e)
        {
            CloseSerialPort();
        }

        private void InitBaudRates()
        {
            int[] baudRates = [1200, 2400, 4800, 9600, 19200, 38400, 57600, 115200, 230400, 460800, 921600];
            foreach (var baudRate in baudRates)
            {
                BaudRateComboBoxCtl.Items.Add(baudRate);
            }

            BaudRateComboBoxCtl.SelectedItem = 115200;
        }

        private void RefreshButton_Click(object sender, RoutedEventArgs e)
        {
            RefreshPorts();
        }

        private void RefreshPorts()
        {
            var selectedPortName = (PortComboBoxCtl.SelectedItem as SerialPortInfo)?.PortName;
            _ports.Clear();

            foreach (var port in GetSerialPortInfos())
            {
                _ports.Add(port);
            }

            if (_ports.Count == 0)
            {
                StatusTextBlockCtl.Text = "状态：未发现可用串口";
                PortComboBoxCtl.SelectedIndex = -1;
                return;
            }

            var previous = _ports.FirstOrDefault(p => p.PortName == selectedPortName);
            PortComboBoxCtl.SelectedItem = previous ?? _ports[0];
            StatusTextBlockCtl.Text = "状态：串口列表已刷新";
        }

        private void InitLcdPreview()
        {
            _lcdBitmap = new WriteableBitmap(LcdWidth, LcdHeight, 96, 96, PixelFormats.Bgra32, null);
            LcdPreviewImageCtl.Source = _lcdBitmap;
            LcdFrameInfoTextBlockCtl.Text = "LCD帧：0";
        }

        private static IEnumerable<SerialPortInfo> GetSerialPortInfos()
        {
            var list = new List<SerialPortInfo>();

            try
            {
                using var searcher = new ManagementObjectSearcher("SELECT Name FROM Win32_PnPEntity WHERE Name LIKE '%(COM%'");
                foreach (var obj in searcher.Get())
                {
                    var name = obj["Name"]?.ToString();
                    if (string.IsNullOrWhiteSpace(name))
                    {
                        continue;
                    }

                    var start = name.LastIndexOf("(COM", StringComparison.OrdinalIgnoreCase);
                    var end = name.LastIndexOf(')');
                    if (start < 0 || end <= start)
                    {
                        continue;
                    }

                    var portName = name.Substring(start + 1, end - start - 1);
                    list.Add(new SerialPortInfo(portName, name));
                }
            }
            catch
            {
                foreach (var port in SerialPort.GetPortNames())
                {
                    list.Add(new SerialPortInfo(port, $"{port} (无详细描述)"));
                }
            }

            foreach (var port in SerialPort.GetPortNames())
            {
                if (list.All(p => !string.Equals(p.PortName, port, StringComparison.OrdinalIgnoreCase)))
                {
                    list.Add(new SerialPortInfo(port, $"{port} (无详细描述)"));
                }
            }

            return list
                .OrderBy(p => p.PortName, StringComparer.OrdinalIgnoreCase)
                .ToList();
        }

        private void OpenButton_Click(object sender, RoutedEventArgs e)
        {
            if (_serialPort?.IsOpen == true)
            {
                return;
            }

            if (PortComboBoxCtl.SelectedItem is not SerialPortInfo selectedPort)
            {
                MessageBox.Show("请先选择串口。", "提示", MessageBoxButton.OK, MessageBoxImage.Information);
                return;
            }

            if (BaudRateComboBoxCtl.SelectedItem is not int baudRate)
            {
                MessageBox.Show("请先选择波特率。", "提示", MessageBoxButton.OK, MessageBoxImage.Information);
                return;
            }

            try
            {
                _serialPort = new SerialPort(selectedPort.PortName, baudRate, Parity.None, 8, StopBits.One)
                {
                    Encoding = Encoding.ASCII,
                    ReadTimeout = 500,
                    WriteTimeout = 500
                };

                _serialPort.DataReceived += SerialPort_DataReceived;
                _serialPort.Open();
                lock (_lcdStreamLock)
                {
                    _lcdStream.Clear();
                }

                UpdateUiByConnectionState(true);
                StatusTextBlockCtl.Text = $"状态：已连接 {selectedPort.PortName} @ {baudRate}";
                AppendReceiveText($"[系统] 打开串口成功：{selectedPort.DisplayText}");
            }
            catch (Exception ex)
            {
                MessageBox.Show($"打开串口失败：{ex.Message}", "错误", MessageBoxButton.OK, MessageBoxImage.Error);
                CloseSerialPort();
            }
        }

        private void CloseButton_Click(object sender, RoutedEventArgs e)
        {
            CloseSerialPort();
        }

        private void CloseSerialPort()
        {
            if (_serialPort == null)
            {
                UpdateUiByConnectionState(false);
                StatusTextBlockCtl.Text = "状态：未连接";
                return;
            }

            try
            {
                _serialPort.DataReceived -= SerialPort_DataReceived;
                if (_serialPort.IsOpen)
                {
                    _serialPort.Close();
                }
            }
            catch
            {
                // ignore
            }
            finally
            {
                _serialPort.Dispose();
                _serialPort = null;
                UpdateUiByConnectionState(false);
                StatusTextBlockCtl.Text = "状态：已断开";
                AppendReceiveText("[系统] 串口已关闭");
            }
        }

        private async void SerialPort_DataReceived(object sender, SerialDataReceivedEventArgs e)
        {
            if (_serialPort?.IsOpen != true)
            {
                return;
            }

            try
            {
                var count = _serialPort.BytesToRead;
                if (count <= 0)
                {
                    return;
                }

                var buffer = new byte[count];
                var read = _serialPort.Read(buffer, 0, count);
                if (read <= 0)
                {
                    return;
                }

                if (read != buffer.Length)
                {
                    Array.Resize(ref buffer, read);
                }

                if (EnableLcdDecodeCheckBoxCtl.IsChecked == true)
                {
                    FeedLcdBytes(buffer);
                }

                await Dispatcher.InvokeAsync(() =>
                {
                    if (EnableLcdDecodeCheckBoxCtl.IsChecked == true)
                    {
                        return;
                    }

                    var text = GetSelectedModeText(ReceiveModeComboBoxCtl) == "HEX"
                        ? BitConverter.ToString(buffer).Replace("-", " ")
                        : Encoding.ASCII.GetString(buffer);

                    AppendReceiveText(text);
                });
            }
            catch (Exception ex)
            {
                await Dispatcher.InvokeAsync(() =>
                {
                    AppendReceiveText($"[错误] 接收数据异常：{ex.Message}");
                });
            }
        }

        private void FeedLcdBytes(byte[] data)
        {
            List<byte[]> frames = [];

            lock (_lcdStreamLock)
            {
                if (data.Length > StreamCapacity)
                {
                    data = data[^StreamCapacity..];
                }

                if (_lcdStream.Count + data.Length > StreamCapacity)
                {
                    var keep = Math.Min(FrameTotal - 1, _lcdStream.Count);
                    if (_lcdStream.Count > keep)
                    {
                        _lcdStream.RemoveRange(0, _lcdStream.Count - keep);
                    }
                }

                _lcdStream.AddRange(data);

                while (_lcdStream.Count >= FrameTotal)
                {
                    var found = FindFrameStart(_lcdStream);
                    if (found < 0)
                    {
                        var keep = Math.Min(FrameTotal - 1, _lcdStream.Count);
                        if (_lcdStream.Count > keep)
                        {
                            _lcdStream.RemoveRange(0, _lcdStream.Count - keep);
                        }

                        break;
                    }

                    var frame = _lcdStream.GetRange(found, FrameBytes).ToArray();
                    frames.Add(frame);
                    _lcdStream.RemoveRange(0, found + FrameTotal);
                }
            }

            foreach (var frame in frames)
            {
                DecodeAndRenderFrame(frame);
            }
        }

        private static int FindFrameStart(List<byte> stream)
        {
            for (var i = 0; i + FrameTotal <= stream.Count; i++)
            {
                var tailIndex = i + FrameBytes;
                var matched = true;
                for (var j = 0; j < TailBytes; j++)
                {
                    if (stream[tailIndex + j] != FrameTail[j])
                    {
                        matched = false;
                        break;
                    }
                }

                if (matched)
                {
                    return i;
                }
            }

            return -1;
        }

        private void DecodeAndRenderFrame(byte[] frame)
        {
            var bgra = new byte[FramePixels * 4];

            for (var i = 0; i < FramePixels; i++)
            {
                var raw = (ushort)((frame[i * 2] << 8) | frame[i * 2 + 1]);

                var r5 = (raw >> 11) & 0x1F;
                var g6 = (raw >> 5) & 0x3F;
                var b5 = raw & 0x1F;

                var r = (byte)((r5 * 255 + 15) / 31);
                var g = (byte)((g6 * 255 + 31) / 63);
                var b = (byte)((b5 * 255 + 15) / 31);

                var idx = i * 4;
                bgra[idx] = b;
                bgra[idx + 1] = g;
                bgra[idx + 2] = r;
                bgra[idx + 3] = 255;
            }

            _ = Dispatcher.InvokeAsync(() =>
            {
                if (_lcdBitmap == null)
                {
                    return;
                }

                _lcdBitmap.WritePixels(new Int32Rect(0, 0, LcdWidth, LcdHeight), bgra, LcdWidth * 4, 0);
                _lcdFrameIndex++;
                LcdFrameInfoTextBlockCtl.Text = $"LCD帧：{_lcdFrameIndex}";
                Title = $"LCD_HOST_DEVICE - Frame {_lcdFrameIndex}";
            });
        }

        private void ClearReceiveButton_Click(object sender, RoutedEventArgs e)
        {
            ReceiveTextBoxCtl.Clear();
        }

        private void SendButton_Click(object sender, RoutedEventArgs e)
        {
            if (_serialPort?.IsOpen != true)
            {
                MessageBox.Show("串口未打开。", "提示", MessageBoxButton.OK, MessageBoxImage.Information);
                return;
            }

            var input = SendTextBoxCtl.Text;
            if (string.IsNullOrWhiteSpace(input))
            {
                return;
            }

            try
            {
                var mode = GetSelectedModeText(SendModeComboBoxCtl);
                if (mode == "HEX")
                {
                    var bytes = ParseHexString(input);
                    _serialPort.Write(bytes, 0, bytes.Length);
                    AppendReceiveText($"[发送 HEX] {BitConverter.ToString(bytes).Replace("-", " ")}");
                }
                else
                {
                    if (AppendNewLineCheckBoxCtl.IsChecked == true)
                    {
                        input += "\r\n";
                    }

                    _serialPort.Write(input);
                    AppendReceiveText($"[发送 ABC] {input}");
                }
            }
            catch (Exception ex)
            {
                MessageBox.Show($"发送失败：{ex.Message}", "错误", MessageBoxButton.OK, MessageBoxImage.Error);
            }
        }

        private void SendFileButton_Click(object sender, RoutedEventArgs e)
        {
            if (_serialPort?.IsOpen != true)
            {
                MessageBox.Show("串口未打开。", "提示", MessageBoxButton.OK, MessageBoxImage.Information);
                return;
            }

            if (!TrySelectFile())
            {
                return;
            }

            try
            {
                var bytes = File.ReadAllBytes(_selectedFilePath!);
                _serialPort.Write(bytes, 0, bytes.Length);
                AppendReceiveText($"[发送文件] {Path.GetFileName(_selectedFilePath)} ({bytes.Length} bytes)");
            }
            catch (Exception ex)
            {
                MessageBox.Show($"发送文件失败：{ex.Message}", "错误", MessageBoxButton.OK, MessageBoxImage.Error);
            }
        }

        private void SelectFileButton_Click(object sender, RoutedEventArgs e)
        {
            _ = TrySelectFile(forceOpenDialog: true);
        }

        private bool TrySelectFile(bool forceOpenDialog = false)
        {
            if (!forceOpenDialog && !string.IsNullOrWhiteSpace(_selectedFilePath) && File.Exists(_selectedFilePath))
            {
                return true;
            }

            var dialog = new OpenFileDialog
            {
                Filter = "所有文件|*.*",
                Title = "选择要打开的文件"
            };

            if (dialog.ShowDialog(this) != true)
            {
                return false;
            }

            UpdateSelectedFilePath(dialog.FileName);
            AppendReceiveText($"[系统] 已选择文件：{Path.GetFileName(dialog.FileName)}");
            return true;
        }

        private void UpdateSelectedFilePath(string? filePath)
        {
            _selectedFilePath = filePath;
            SelectedFileTextBoxCtl.Text = string.IsNullOrWhiteSpace(filePath) ? "(未选择文件)" : filePath;
        }

        private void UpdateUiByConnectionState(bool isConnected)
        {
            OpenButtonCtl.IsEnabled = !isConnected;
            CloseButtonCtl.IsEnabled = isConnected;
            PortComboBoxCtl.IsEnabled = !isConnected;
            BaudRateComboBoxCtl.IsEnabled = !isConnected;
            RefreshButtonCtl.IsEnabled = !isConnected;
        }

        private static string GetSelectedModeText(ComboBox comboBox)
        {
            return (comboBox.SelectedItem as ComboBoxItem)?.Content?.ToString() ?? "ABC";
        }

        private static byte[] ParseHexString(string input)
        {
            var cleaned = input.Replace(" ", string.Empty)
                               .Replace("\r", string.Empty)
                               .Replace("\n", string.Empty);

            if (cleaned.Length % 2 != 0)
            {
                throw new FormatException("HEX 数据长度必须为偶数。例：0A FF 1C");
            }

            var bytes = new byte[cleaned.Length / 2];
            for (var i = 0; i < bytes.Length; i++)
            {
                bytes[i] = Convert.ToByte(cleaned.Substring(i * 2, 2), 16);
            }

            return bytes;
        }

        private void AppendReceiveText(string text)
        {
            var stamp = DateTime.Now.ToString("HH:mm:ss.fff");
            ReceiveTextBoxCtl.AppendText($"[{stamp}] {text}{Environment.NewLine}");
            ReceiveTextBoxCtl.ScrollToEnd();
        }

        private sealed class SerialPortInfo(string portName, string displayText)
        {
            public string PortName { get; } = portName;
            public string DisplayText { get; } = displayText;
        }
    }
