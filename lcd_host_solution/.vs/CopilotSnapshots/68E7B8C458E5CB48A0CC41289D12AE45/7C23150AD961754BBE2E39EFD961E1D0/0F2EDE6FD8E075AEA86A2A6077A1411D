<Window x:Class="lcd_host.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:lcd_host"
        mc:Ignorable="d"
        Title="LCD_HOST_DEVICE"
        Height="700"
        Width="1100"
        MinWidth="980"
        MinHeight="620"
        Background="#0F172A"
        Loaded="Window_Loaded"
        Closing="Window_Closing">
    <Window.Resources>
        <LinearGradientBrush x:Key="PanelBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#111827" Offset="0" />
            <GradientStop Color="#1E293B" Offset="1" />
        </LinearGradientBrush>

        <Style TargetType="GroupBox">
            <Setter Property="Margin" Value="0,0,0,12" />
            <Setter Property="Padding" Value="10" />
            <Setter Property="BorderBrush" Value="#334155" />
            <Setter Property="Background" Value="#0B1220" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="#E2E8F0" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="Margin" Value="4" />
            <Setter Property="Padding" Value="14,7" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="#4F46E5" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="4" />
            <Setter Property="Padding" Value="8" />
            <Setter Property="BorderBrush" Value="#334155" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="#0F172A" />
            <Setter Property="Foreground" Value="#E2E8F0" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Margin" Value="4" />
            <Setter Property="Padding" Value="6" />
            <Setter Property="BorderBrush" Value="#334155" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="MinWidth" Value="120" />
            <Setter Property="Background" Value="#0F172A" />
            <Setter Property="Foreground" Value="#E2E8F0" />
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#CBD5E1" />
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#CBD5E1" />
        </Style>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Margin="0,0,0,12"
                Padding="12"
                CornerRadius="10"
                BorderBrush="#334155"
                BorderThickness="1"
                Background="{StaticResource PanelBackgroundBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Margin="4,0"
                               VerticalAlignment="Center"
                               FontWeight="SemiBold"
                               Text="端口" />
                    <ComboBox x:Name="PortComboBox"
                              Width="360"
                              DisplayMemberPath="DisplayText"
                              SelectedValuePath="PortName" />

                    <TextBlock Margin="18,0,4,0"
                               VerticalAlignment="Center"
                               FontWeight="SemiBold"
                               Text="波特率" />
                    <ComboBox x:Name="BaudRateComboBox" Width="130" />

                    <Button x:Name="RefreshButton" Content="刷新端口" Click="RefreshButton_Click" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="OpenButton" Content="打开串口" Click="OpenButton_Click" />
                    <Button x:Name="CloseButton"
                            Content="关闭串口"
                            Background="#F15E5E"
                            Click="CloseButton_Click" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="360" />
            </Grid.ColumnDefinitions>

            <Grid Margin="0,0,12,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="1.2*" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

            <GroupBox Header="串口接收区域" Margin="0,0,0,12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" Margin="0,0,0,8">
                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                            <TextBlock Margin="4,0"
                                       VerticalAlignment="Center"
                                       FontWeight="SemiBold"
                                       Text="显示编码" />
                            <ComboBox x:Name="ReceiveModeComboBox" Width="120">
                                <ComboBoxItem Content="ABC" IsSelected="True" />
                                <ComboBoxItem Content="HEX" />
                            </ComboBox>
                            <CheckBox x:Name="EnableLcdDecodeCheckBox"
                                      Margin="12,0,0,0"
                                      IsChecked="True"
                                      VerticalAlignment="Center"
                                      Content="启用LCD帧解析" />
                        </StackPanel>

                        <Button DockPanel.Dock="Right"
                                HorizontalAlignment="Right"
                                Content="清空接收"
                                Background="#6A768A"
                                Click="ClearReceiveButton_Click" />
                    </DockPanel>

                    <TextBox x:Name="ReceiveTextBox"
                             Grid.Row="1"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             TextWrapping="Wrap"
                             IsReadOnly="True"
                             FontFamily="Consolas"
                             FontSize="13" />
                </Grid>
            </GroupBox>

                <GroupBox Grid.Row="1" Header="LCD 预览 (RGB565 + Tail: 0D 00 07 21)">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Border Margin="4"
                                CornerRadius="6"
                                BorderBrush="#334155"
                                BorderThickness="1"
                                Background="#020617">
                            <Viewbox Stretch="Uniform" Margin="8">
                                <Image x:Name="LcdPreviewImage"
                                       Width="160"
                                       Height="80"
                                       Stretch="Fill"
                                       SnapsToDevicePixels="True" />
                            </Viewbox>
                        </Border>

                        <TextBlock x:Name="LcdFrameInfoTextBlock"
                                   Grid.Row="1"
                                   Margin="6,6,6,2"
                                   Text="LCD帧：0"
                                   Foreground="#93C5FD"
                                   FontWeight="SemiBold" />
                    </Grid>
                </GroupBox>
            </Grid>

            <GroupBox Grid.Column="1" Header="串口发送区域">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Grid.Row="0">
                        <TextBlock Margin="4,0"
                                   VerticalAlignment="Center"
                                   FontWeight="SemiBold"
                                   Text="发送编码" />
                        <ComboBox x:Name="SendModeComboBox" Width="120">
                            <ComboBoxItem Content="ABC" IsSelected="True" />
                            <ComboBoxItem Content="HEX" />
                        </ComboBox>
                    </StackPanel>

                    <TextBox x:Name="SendTextBox"
                             Grid.Row="1"
                             Margin="4"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             FontFamily="Consolas"
                             FontSize="13" />

                    <CheckBox x:Name="AppendNewLineCheckBox"
                              Grid.Row="2"
                              Margin="8,6,8,4"
                              Content="发送时追加换行 (CRLF)" />

                    <Grid Grid.Row="3" Margin="4,2,4,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="SelectedFileTextBox"
                                 IsReadOnly="True"
                                 Margin="0,0,6,0"
                                 ToolTip="后续拓展可直接使用该已选文件" />
                        <Button Grid.Column="1"
                                Content="打开文件"
                                Background="#0EA5A4"
                                Click="SelectFileButton_Click" />
                    </Grid>

                    <StackPanel Grid.Row="4"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right">
                        <Button Content="发送文本/命令" Click="SendButton_Click" />
                        <Button Content="发送文件" Background="#00A870" Click="SendFileButton_Click" />
                    </StackPanel>
                </Grid>
            </GroupBox>
        </Grid>

        <Border Grid.Row="2"
                Padding="10"
                CornerRadius="8"
                BorderBrush="#334155"
                BorderThickness="1"
                Background="{StaticResource PanelBackgroundBrush}">
            <TextBlock x:Name="StatusTextBlock"
                       FontWeight="SemiBold"
                       Text="状态：未连接"
                       Foreground="#93C5FD" />
        </Border>
    </Grid>
</Window>
