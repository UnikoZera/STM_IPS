        {
            OpenButtonCtl.IsEnabled = !isConnected;
            CloseButtonCtl.IsEnabled = isConnected;
            PortComboBoxCtl.IsEnabled = !isConnected;
            BaudRateComboBoxCtl.IsEnabled = !isConnected;
            DataBitsComboBoxCtl.IsEnabled = !isConnected;
            ParityComboBoxCtl.IsEnabled = !isConnected;
            StopBitsComboBoxCtl.IsEnabled = !isConnected;
            HandshakeComboBoxCtl.IsEnabled = !isConnected;
            DtrEnableCheckBoxCtl.IsEnabled = !isConnected;
            RtsEnableCheckBoxCtl.IsEnabled = !isConnected;
            RefreshButtonCtl.IsEnabled = !isConnected;
        }

        private static T GetSelectedEnum<T>(ComboBox comboBox, T fallback) where T : struct
        {
            return comboBox.SelectedItem is SerialOption<T> selected ? selected.Value : fallback;
        }

        private static string GetParityShortName(Parity parity)
        {
            return parity switch
            {
                Parity.None => "N",
                Parity.Odd => "O",
                Parity.Even => "E",
                Parity.Mark => "M",
                Parity.Space => "S",
                _ => "N"
            };
        }

        private static string GetStopBitsShortName(StopBits stopBits)
        {
            return stopBits switch
            {
                StopBits.One => "1",
                StopBits.OnePointFive => "1.5",
                StopBits.Two => "2",
                _ => "1"
            };
        }

        private static string GetSelectedModeText(ComboBox comboBox)
        {
            return (comboBox.SelectedItem as ComboBoxItem)?.Content?.ToString() ?? "ABC";
        }

        private static byte[] ParseHexString(string input)
        {
            var cleaned = input.Replace(" ", string.Empty)
                               .Replace("\r", string.Empty)
                               .Replace("\n", string.Empty);

            if (cleaned.Length % 2 != 0)
            {
                throw new FormatException("HEX 数据长度必须为偶数。例：0A FF 1C");
            }

            var bytes = new byte[cleaned.Length / 2];
            for (var i = 0; i < bytes.Length; i++)
            {
                bytes[i] = Convert.ToByte(cleaned.Substring(i * 2, 2), 16);
            }

            return bytes;
        }

        private void AppendTxLog(string text)
        {
            AppendColoredLog("[tx]", text, "#60A5FA");
        }

        private void AppendRxLog(string text)
        {
            AppendColoredLog("[rx]", text, "#34D399");
        }

        private void AppendSystemLog(string text)
        {
            AppendColoredLog("[sys]", text, "#FBBF24");
        }

        private void AppendColoredLog(string tag, string text, string hexColor)
        {
            if (!Dispatcher.CheckAccess())
            {
                _ = Dispatcher.InvokeAsync(() => AppendColoredLog(tag, text, hexColor));
                return;
            }

            var stamp = DateTime.Now.ToString("HH:mm:ss.fff");
            var paragraph = new Paragraph { Margin = new Thickness(0) };
            paragraph.Inlines.Add(new Run($"[{stamp}] ")
            {
                Foreground = new SolidColorBrush((Color)ColorConverter.ConvertFromString("#94A3B8"))
            });
            paragraph.Inlines.Add(new Run($"{tag} ")
            {
                Foreground = new SolidColorBrush((Color)ColorConverter.ConvertFromString(hexColor)),
                FontWeight = FontWeights.SemiBold
            });
            paragraph.Inlines.Add(new Run(text)
            {
                Foreground = new SolidColorBrush((Color)ColorConverter.ConvertFromString("#F8FAFC"))
            });

            ReceiveRichTextBoxCtl.Document.Blocks.Add(paragraph);
            ReceiveRichTextBoxCtl.ScrollToEnd();
        }

        private sealed class SerialPortInfo(string portName, string displayText)
        {
            public string PortName { get; } = portName;
            public string DisplayText { get; } = displayText;
        }

        private sealed class SerialOption<T>(T value, string text)
        {
            public T Value { get; } = value;
            public string Text { get; } = text;
            public override string ToString() => Text;
        }
    }
