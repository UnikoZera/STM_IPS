        private bool TrySelectFile(bool forceOpenDialog = false)
        {
            if (!forceOpenDialog && !string.IsNullOrWhiteSpace(_selectedFilePath) && File.Exists(_selectedFilePath))
            {
                return true;
            }

            var dialog = new OpenFileDialog
            {
                Filter = "所有文件|*.*",
                Title = "选择要打开的文件"
            };

            if (dialog.ShowDialog(this) != true)
            {
                return false;
            }

            UpdateSelectedFilePath(dialog.FileName);
            AppendSystemLog($"已选择文件：{Path.GetFileName(dialog.FileName)}");
            return true;
        }

        private void UpdateSelectedFilePath(string? filePath)
        {
            _selectedFilePath = filePath;
            SelectedFileTextBoxCtl.Text = string.IsNullOrWhiteSpace(filePath) ? "(未选择文件)" : filePath;
        }

        private void LoadConfig()
        {
            try
            {
                if (!File.Exists(_configFilePath))
                {
                    UpdateSelectedFilePath(null);
                    return;
                }

                var json = File.ReadAllText(_configFilePath);
                var config = JsonSerializer.Deserialize<UiConfig>(json);
                if (config == null)
                {
                    UpdateSelectedFilePath(null);
                    return;
                }

                _preferredPortName = config.PortName;
                if (config.BaudRate > 0)
                {
                    BaudRateComboBoxCtl.SelectedItem = config.BaudRate;
                }

                if (config.DataBits is 5 or 6 or 7 or 8)
                {
                    DataBitsComboBoxCtl.SelectedItem = config.DataBits;
                }

                SelectEnumOption(ParityComboBoxCtl, config.Parity, Parity.None);
                SelectEnumOption(StopBitsComboBoxCtl, config.StopBits, StopBits.One);
                SelectEnumOption(HandshakeComboBoxCtl, config.Handshake, Handshake.None);

                DtrEnableCheckBoxCtl.IsChecked = config.DtrEnable;
                RtsEnableCheckBoxCtl.IsChecked = config.RtsEnable;
                EnableLcdDecodeCheckBoxCtl.IsChecked = config.LcdDecodeEnabled;

                SelectTextOption(ReceiveModeComboBoxCtl, config.ReceiveMode, "ABC");
                SelectTextOption(SendModeComboBoxCtl, config.SendMode, "ABC");
                SelectTextOption(LineEndingComboBoxCtl, config.LineEndingMode, "无");
                _receiveHexMode = GetSelectedModeText(ReceiveModeComboBoxCtl) == "HEX";
                _lcdDecodeEnabled = EnableLcdDecodeCheckBoxCtl.IsChecked == true;
                UpdateLcdPreviewVisibility();

                UpdateSelectedFilePath(File.Exists(config.SelectedFilePath) ? config.SelectedFilePath : null);
            }
            catch
            {
                UpdateSelectedFilePath(null);
            }
        }

        private void SaveConfig()
        {
            try
            {
                var config = new UiConfig
                {
                    PortName = (PortComboBoxCtl.SelectedItem as SerialPortInfo)?.PortName,
                    BaudRate = BaudRateComboBoxCtl.SelectedItem as int? ?? 115200,
                    DataBits = DataBitsComboBoxCtl.SelectedItem as int? ?? 8,
                    Parity = GetSelectedEnum(ParityComboBoxCtl, Parity.None),
                    StopBits = GetSelectedEnum(StopBitsComboBoxCtl, StopBits.One),
                    Handshake = GetSelectedEnum(HandshakeComboBoxCtl, Handshake.None),
                    DtrEnable = DtrEnableCheckBoxCtl.IsChecked == true,
                    RtsEnable = RtsEnableCheckBoxCtl.IsChecked == true,
                    LcdDecodeEnabled = EnableLcdDecodeCheckBoxCtl.IsChecked == true,
                    ReceiveMode = GetSelectedModeText(ReceiveModeComboBoxCtl),
                    SendMode = GetSelectedModeText(SendModeComboBoxCtl),
                    LineEndingMode = GetSelectedModeText(LineEndingComboBoxCtl),
                    SelectedFilePath = _selectedFilePath ?? string.Empty
                };

                var folder = Path.GetDirectoryName(_configFilePath);
                if (!string.IsNullOrWhiteSpace(folder))
                {
                    Directory.CreateDirectory(folder);
                }

                var json = JsonSerializer.Serialize(config, new JsonSerializerOptions { WriteIndented = true });
                File.WriteAllText(_configFilePath, json);
            }
            catch
            {
                // ignore config write failure
            }
        }

        private static void SelectEnumOption<T>(ComboBox comboBox, T value, T fallback) where T : struct
        {
            var selected = comboBox.Items.OfType<SerialOption<T>>().FirstOrDefault(i => EqualityComparer<T>.Default.Equals(i.Value, value));
            comboBox.SelectedItem = selected ?? comboBox.Items.OfType<SerialOption<T>>().FirstOrDefault(i => EqualityComparer<T>.Default.Equals(i.Value, fallback));
        }

        private static void SelectTextOption(ComboBox comboBox, string? text, string fallback)
        {
            var target = string.IsNullOrWhiteSpace(text) ? fallback : text;
            var selected = comboBox.Items.OfType<ComboBoxItem>().FirstOrDefault(i => string.Equals(i.Content?.ToString(), target, StringComparison.OrdinalIgnoreCase));
            comboBox.SelectedItem = selected ?? comboBox.Items.OfType<ComboBoxItem>().FirstOrDefault(i => string.Equals(i.Content?.ToString(), fallback, StringComparison.OrdinalIgnoreCase));
        }

