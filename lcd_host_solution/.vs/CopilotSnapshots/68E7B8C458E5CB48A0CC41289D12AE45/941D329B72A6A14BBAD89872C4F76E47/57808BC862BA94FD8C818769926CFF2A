        private void CloseSerialPort()
        {
            if (_serialPort == null)
            {
                UpdateUiByConnectionState(false);
                StatusTextBlockCtl.Text = "状态：未连接";
                return;
            }

            try
            {
                _readerCts?.Cancel();
                var readerTask = _readerTask;
                if (readerTask != null && !readerTask.IsCompleted)
                {
                    readerTask.Wait(500);
                }

                if (_serialPort.IsOpen)
                {
                    _serialPort.Close();
                }
            }
            catch
            {
                // ignore
            }
            finally
            {
                _serialPort.Dispose();
                _serialPort = null;
                _readerCts?.Dispose();
                _readerCts = null;
                _readerTask = null;
                UpdateUiByConnectionState(false);
                StatusTextBlockCtl.Text = "状态：已断开";
                AppendSystemLog("串口已关闭");
            }
        }

        private void StartSerialReader(SerialPort port)
        {
            _readerCts?.Cancel();
            _readerCts?.Dispose();
            _readerCts = new CancellationTokenSource();
            var token = _readerCts.Token;

            _readerTask = Task.Run(async () =>
            {
                var buffer = new byte[4096];

                while (!token.IsCancellationRequested)
                {
                    try
                    {
                        var read = await port.BaseStream.ReadAsync(buffer.AsMemory(0, buffer.Length), token);
                        if (read <= 0)
                        {
                            continue;
                        }

                        var incoming = new byte[read];
                        Buffer.BlockCopy(buffer, 0, incoming, 0, read);
                        HandleIncomingBytes(incoming);
                    }
                    catch (OperationCanceledException)
                    {
                        break;
                    }
                    catch (ObjectDisposedException)
                    {
                        break;
                    }
                    catch (Exception ex)
                    {
                        await Dispatcher.InvokeAsync(() =>
                        {
                            AppendSystemLog($"[错误] 接收数据异常：{ex.Message}");
                        });
                    }
                }
            }, token);
        }

        private void HandleIncomingBytes(byte[] buffer)
        {
            var decodeEnabled = _lcdDecodeEnabled;
            var session = _lcdDecodeSession;
            if (decodeEnabled)
            {
                FeedLcdBytes(buffer, session);
                _lcdBytesCounter += buffer.Length;
                var now = Environment.TickCount64;
                if (now - _lastLcdStatsTick >= 1000)
                {
                    var bytes = _lcdBytesCounter;
                    _lcdBytesCounter = 0;
                    _lastLcdStatsTick = now;
                    EnqueueLog("[rx]", $"[lcd] {bytes / 1024.0:F1} KB/s", "#34D399");
                }

                return;
            }

            var text = _receiveHexMode
                ? BitConverter.ToString(buffer).Replace("-", " ")
                : Encoding.ASCII.GetString(buffer);

            EnqueueLog("[rx]", text, "#34D399");
        }

        private void FeedLcdBytes(byte[] data, int session)
        {
            List<byte[]> frames = [];

            lock (_lcdStreamLock)
            {
                if (data.Length > StreamCapacity)
                {
                    data = data[^StreamCapacity..];
                }

                if (_lcdStream.Count + data.Length > StreamCapacity)
                {
                    var keep = Math.Min(FrameTotal - 1, _lcdStream.Count);
                    if (_lcdStream.Count > keep)
                    {
                        _lcdStream.RemoveRange(0, _lcdStream.Count - keep);
                    }
                }

                _lcdStream.AddRange(data);

                while (_lcdStream.Count >= FrameTotal)
                {
                    var found = FindFrameStart(_lcdStream);
                    if (found < 0)
                    {
                        var keep = Math.Min(FrameTotal - 1, _lcdStream.Count);
                        if (_lcdStream.Count > keep)
                        {
                            _lcdStream.RemoveRange(0, _lcdStream.Count - keep);
                        }

                        break;
                    }

                    var frame = _lcdStream.GetRange(found, FrameBytes).ToArray();
                    frames.Add(frame);
                    _lcdStream.RemoveRange(0, found + FrameTotal);
                }
            }

            if (frames.Count > 0)
            {
                DecodeAndRenderFrame(frames[^1], frames.Count, session);
            }
        }

        private static int FindFrameStart(List<byte> stream)
        {
            for (var i = 0; i + FrameTotal <= stream.Count; i++)
            {
                var tailIndex = i + FrameBytes;
                var matched = true;
                for (var j = 0; j < TailBytes; j++)
                {
                    if (stream[tailIndex + j] != FrameTail[j])
                    {
                        matched = false;
                        break;
                    }
                }

                if (matched)
                {
                    return i;
                }
            }

            return -1;
        }

        private void DecodeAndRenderFrame(byte[] frame, int extractedFrameCount, int session)
        {
            var bgra = new byte[FramePixels * 4];

            for (var i = 0; i < FramePixels; i++)
            {
                var raw = (ushort)((frame[i * 2] << 8) | frame[i * 2 + 1]);

                var r5 = (raw >> 11) & 0x1F;
                var g6 = (raw >> 5) & 0x3F;
                var b5 = raw & 0x1F;

                var r = (byte)((r5 * 255 + 15) / 31);
                var g = (byte)((g6 * 255 + 31) / 63);
                var b = (byte)((b5 * 255 + 15) / 31);

                var idx = i * 4;
                bgra[idx] = b;
                bgra[idx + 1] = g;
                bgra[idx + 2] = r;
                bgra[idx + 3] = 255;
            }

            _ = Dispatcher.InvokeAsync(() =>
            {
                if (_lcdBitmap == null || !_lcdDecodeEnabled || session != _lcdDecodeSession)
                {
                    return;
                }

                _lcdBitmap.WritePixels(new Int32Rect(0, 0, LcdWidth, LcdHeight), bgra, LcdWidth * 4, 0);
                _lcdFrameIndex += (ulong)Math.Max(1, extractedFrameCount);
                LcdFrameInfoTextBlockCtl.Text = $"LCD帧：{_lcdFrameIndex}";
                Title = $"LCD_HOST_DEVICE - Frame {_lcdFrameIndex}";
            });
        }

