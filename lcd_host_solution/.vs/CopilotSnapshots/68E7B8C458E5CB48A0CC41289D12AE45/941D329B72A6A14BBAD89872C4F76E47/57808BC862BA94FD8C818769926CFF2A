        private static byte[] ParseHexString(string input)
        {
            var cleaned = input.Replace(" ", string.Empty)
                               .Replace("\r", string.Empty)
                               .Replace("\n", string.Empty);

            if (cleaned.Length % 2 != 0)
            {
                throw new FormatException("HEX 数据长度必须为偶数。例：0A FF 1C");
            }

            var bytes = new byte[cleaned.Length / 2];
            for (var i = 0; i < bytes.Length; i++)
            {
                bytes[i] = Convert.ToByte(cleaned.Substring(i * 2, 2), 16);
            }

            return bytes;
        }

        private void AppendTxLog(string text)
        {
            EnqueueLog("[tx]", text, "#60A5FA");
        }

        private void AppendRxLog(string text)
        {
            EnqueueLog("[rx]", text, "#34D399");
        }

        private void AppendSystemLog(string text)
        {
            EnqueueLog("[sys]", text, "#FBBF24");
        }

        private void EnqueueLog(string tag, string text, string hexColor)
        {
            var normalized = text;
            if (normalized.Length > 2000)
            {
                normalized = normalized[..2000] + " ...";
            }

            if (Interlocked.Increment(ref _pendingLogCount) > 5000)
            {
                Interlocked.Decrement(ref _pendingLogCount);
                return;
            }

            _logQueue.Enqueue(new LogEntry(tag, normalized, hexColor, DateTime.Now));
        }

        private void FlushLogs()
        {
            if (!Dispatcher.CheckAccess())
            {
                return;
            }

            var added = false;
            for (var i = 0; i < LogFlushBatchSize; i++)
            {
                if (!_logQueue.TryDequeue(out var entry))
                {
                    break;
                }

                Interlocked.Decrement(ref _pendingLogCount);
                added = true;

                var paragraph = new Paragraph { Margin = new Thickness(0) };
                paragraph.Inlines.Add(new Run($"[{entry.Time:HH:mm:ss.fff}] ")
                {
                    Foreground = new SolidColorBrush((Color)ColorConverter.ConvertFromString("#94A3B8"))
                });
                paragraph.Inlines.Add(new Run($"{entry.Tag} ")
                {
                    Foreground = new SolidColorBrush((Color)ColorConverter.ConvertFromString(entry.ColorHex)),
                    FontWeight = FontWeights.SemiBold
                });
                paragraph.Inlines.Add(new Run(entry.Message)
                {
                    Foreground = new SolidColorBrush((Color)ColorConverter.ConvertFromString("#F8FAFC"))
                });

                ReceiveRichTextBoxCtl.Document.Blocks.Add(paragraph);
            }

            while (ReceiveRichTextBoxCtl.Document.Blocks.Count > MaxUiLogBlocks)
            {
                ReceiveRichTextBoxCtl.Document.Blocks.Remove(ReceiveRichTextBoxCtl.Document.Blocks.FirstBlock);
            }

            if (added)
            {
                ReceiveRichTextBoxCtl.ScrollToEnd();
            }
        }

