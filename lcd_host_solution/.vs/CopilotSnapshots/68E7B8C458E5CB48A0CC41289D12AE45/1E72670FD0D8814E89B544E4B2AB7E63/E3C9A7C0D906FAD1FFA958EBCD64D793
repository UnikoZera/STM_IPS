<Window x:Class="lcd_host.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:lcd_host"
        mc:Ignorable="d"
        Title="LCD_HOST_DEVICE"
        Height="700"
        Width="1100"
        MinWidth="980"
        MinHeight="620"
        Background="#F3F6FB"
        Loaded="Window_Loaded"
        Closing="Window_Closing">
    <Window.Resources>
        <Style TargetType="GroupBox">
            <Setter Property="Margin" Value="0,0,0,12" />
            <Setter Property="Padding" Value="10" />
            <Setter Property="BorderBrush" Value="#DFE6F3" />
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="13" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="Margin" Value="4" />
            <Setter Property="Padding" Value="14,7" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="#3C7BFF" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="4" />
            <Setter Property="Padding" Value="8" />
            <Setter Property="BorderBrush" Value="#D4DDED" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Margin" Value="4" />
            <Setter Property="Padding" Value="6" />
            <Setter Property="BorderBrush" Value="#D4DDED" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="MinWidth" Value="120" />
        </Style>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Margin="0,0,0,12"
                Padding="12"
                CornerRadius="10"
                BorderBrush="#DFE6F3"
                BorderThickness="1"
                Background="White">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Margin="4,0"
                               VerticalAlignment="Center"
                               FontWeight="SemiBold"
                               Text="端口" />
                    <ComboBox x:Name="PortComboBox"
                              Width="360"
                              DisplayMemberPath="DisplayText"
                              SelectedValuePath="PortName" />

                    <TextBlock Margin="18,0,4,0"
                               VerticalAlignment="Center"
                               FontWeight="SemiBold"
                               Text="波特率" />
                    <ComboBox x:Name="BaudRateComboBox" Width="130" />

                    <Button x:Name="RefreshButton" Content="刷新端口" Click="RefreshButton_Click" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="OpenButton" Content="打开串口" Click="OpenButton_Click" />
                    <Button x:Name="CloseButton"
                            Content="关闭串口"
                            Background="#F15E5E"
                            Click="CloseButton_Click" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="340" />
            </Grid.ColumnDefinitions>

            <GroupBox Header="串口接收区域" Margin="0,0,12,12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" Margin="0,0,0,8">
                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                            <TextBlock Margin="4,0"
                                       VerticalAlignment="Center"
                                       FontWeight="SemiBold"
                                       Text="显示编码" />
                            <ComboBox x:Name="ReceiveModeComboBox" Width="120">
                                <ComboBoxItem Content="ABC" IsSelected="True" />
                                <ComboBoxItem Content="HEX" />
                            </ComboBox>
                        </StackPanel>

                        <Button DockPanel.Dock="Right"
                                HorizontalAlignment="Right"
                                Content="清空接收"
                                Background="#6A768A"
                                Click="ClearReceiveButton_Click" />
                    </DockPanel>

                    <TextBox x:Name="ReceiveTextBox"
                             Grid.Row="1"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             TextWrapping="Wrap"
                             IsReadOnly="True"
                             FontFamily="Consolas"
                             FontSize="13" />
                </Grid>
            </GroupBox>

            <GroupBox Grid.Column="1" Header="串口发送区域">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Grid.Row="0">
                        <TextBlock Margin="4,0"
                                   VerticalAlignment="Center"
                                   FontWeight="SemiBold"
                                   Text="发送编码" />
                        <ComboBox x:Name="SendModeComboBox" Width="120">
                            <ComboBoxItem Content="ABC" IsSelected="True" />
                            <ComboBoxItem Content="HEX" />
                        </ComboBox>
                    </StackPanel>

                    <TextBox x:Name="SendTextBox"
                             Grid.Row="1"
                             Margin="4"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             FontFamily="Consolas"
                             FontSize="13" />

                    <CheckBox x:Name="AppendNewLineCheckBox"
                              Grid.Row="2"
                              Margin="8,6,8,4"
                              Content="发送时追加换行 (CRLF)" />

                    <StackPanel Grid.Row="3"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right">
                        <Button Content="发送文本/命令" Click="SendButton_Click" />
                        <Button Content="发送文件" Background="#00A870" Click="SendFileButton_Click" />
                    </StackPanel>
                </Grid>
            </GroupBox>
        </Grid>

        <Border Grid.Row="2"
                Padding="10"
                CornerRadius="8"
                BorderBrush="#DFE6F3"
                BorderThickness="1"
                Background="White">
            <TextBlock x:Name="StatusTextBlock"
                       FontWeight="SemiBold"
                       Text="状态：未连接"
                       Foreground="#6A768A" />
        </Border>
    </Grid>
</Window>
