<Window x:Class="lcd_host.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:lcd_host"
        mc:Ignorable="d"
        Title="LCD_HOST_DEVICE"
        Height="700"
        Width="1100"
        MinWidth="760"
        MinHeight="520"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanResize"
        FontFamily="Segoe UI"
        Background="{DynamicResource WindowBackgroundBrush}"
        Foreground="{DynamicResource PrimaryForegroundBrush}"
        Loaded="Window_Loaded"
        Closing="Window_Closing">
    <Window.Resources>
        <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#0B1220" />
        <SolidColorBrush x:Key="PrimaryForegroundBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="PanelBorderBrush" Color="#334155" />
        <SolidColorBrush x:Key="GroupBackgroundBrush" Color="#111827" />
        <SolidColorBrush x:Key="PrimaryButtonBrush" Color="#6366F1" />
        <SolidColorBrush x:Key="InputBackgroundBrush" Color="#0F172A" />
        <SolidColorBrush x:Key="InputForegroundBrush" Color="#F8FAFC" />
        <SolidColorBrush x:Key="TextForegroundBrush" Color="#F1F5F9" />
        <SolidColorBrush x:Key="CheckForegroundBrush" Color="#E2E8F0" />
        <SolidColorBrush x:Key="ParameterLabelBrush" Color="#BFDBFE" />

        <LinearGradientBrush x:Key="PanelBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#111827" Offset="0" />
            <GradientStop Color="#1E293B" Offset="1" />
        </LinearGradientBrush>

        <Style x:Key="SoftGridSplitterStyle" TargetType="GridSplitter">
            <Setter Property="Background" Value="#334155" />
            <Setter Property="Opacity" Value="0.6" />
            <Setter Property="ShowsPreview" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GridSplitter">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="2" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#60A5FA" />
                    <Setter Property="Opacity" Value="0.95" />
                </Trigger>
                <Trigger Property="IsKeyboardFocused" Value="True">
                    <Setter Property="Background" Value="#38BDF8" />
                    <Setter Property="Opacity" Value="0.95" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="GroupBox">
            <Setter Property="Margin" Value="0,0,0,12" />
            <Setter Property="Padding" Value="10" />
            <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
            <Setter Property="Background" Value="{DynamicResource GroupBackgroundBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="{DynamicResource CheckForegroundBrush}" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="Margin" Value="4" />
            <Setter Property="Padding" Value="14,7" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="{DynamicResource PrimaryButtonBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="4" />
            <Setter Property="Padding" Value="8" />
            <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource InputForegroundBrush}" />
        </Style>

        <Style TargetType="RichTextBox">
            <Setter Property="Margin" Value="4" />
            <Setter Property="Padding" Value="8" />
            <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource InputForegroundBrush}" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Margin" Value="4" />
            <Setter Property="Padding" Value="6" />
            <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="MinWidth" Value="120" />
            <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource InputForegroundBrush}" />
            <Setter Property="TextElement.Foreground" Value="{DynamicResource InputForegroundBrush}" />
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="1" />
                    <Setter Property="Foreground" Value="#E2E8F0" />
                    <Setter Property="Background" Value="#1E293B" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{DynamicResource InputForegroundBrush}" />
            <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}" />
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextForegroundBrush}" />
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource CheckForegroundBrush}" />
        </Style>

        <Style x:Key="ParameterLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E2E8F0" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="4,0" />
        </Style>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Margin="0,0,0,12"
                Padding="12"
                CornerRadius="10"
                BorderBrush="{DynamicResource PanelBorderBrush}"
                BorderThickness="1"
                Background="{StaticResource PanelBackgroundBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <WrapPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Margin="0,0,8,0">
                            <TextBlock Style="{StaticResource ParameterLabelStyle}" Text="端口" />
                            <ComboBox x:Name="PortComboBox"
                                      Width="360"
                                      DisplayMemberPath="DisplayText"
                                      SelectedValuePath="PortName"
                                      SelectionChanged="PortComboBox_SelectionChanged" />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,0,8,0">
                            <TextBlock Style="{StaticResource ParameterLabelStyle}" Text="波特率" />
                            <ComboBox x:Name="BaudRateComboBox" Width="130" />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,0,8,0">
                            <TextBlock Style="{StaticResource ParameterLabelStyle}" Text="数据位" />
                            <ComboBox x:Name="DataBitsComboBox" Width="80" />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,0,8,0">
                            <TextBlock Style="{StaticResource ParameterLabelStyle}" Text="校验位" />
                            <ComboBox x:Name="ParityComboBox" Width="100" />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,0,8,0">
                            <TextBlock Style="{StaticResource ParameterLabelStyle}" Text="停止位" />
                            <ComboBox x:Name="StopBitsComboBox" Width="120" />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,0,8,0">
                            <TextBlock Style="{StaticResource ParameterLabelStyle}" Text="流控" />
                            <ComboBox x:Name="HandshakeComboBox" Width="190" />
                        </StackPanel>
                    </WrapPanel>

                    <WrapPanel Grid.Row="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,6,0,0">
                        <CheckBox x:Name="DtrEnableCheckBox"
                                  Margin="10,0,0,0"
                                  VerticalAlignment="Center"
                                  Content="DTR" />

                        <CheckBox x:Name="RtsEnableCheckBox"
                                  Margin="8,0,0,0"
                                  VerticalAlignment="Center"
                                  Content="RTS" />

                        <Button x:Name="RefreshButton" Content="刷新端口" Click="RefreshButton_Click" />
                        <Button x:Name="OpenButton" Content="打开串口" Click="OpenButton_Click" />
                        <Button x:Name="CloseButton"
                                Content="关闭串口"
                                Background="#F15E5E"
                                Click="CloseButton_Click" />
                    </WrapPanel>
                </Grid>

                <TextBlock x:Name="PortDetailTextBlock"
                           Grid.Row="1"
                           Margin="6,8,6,0"
                           Foreground="#BFDBFE"
                           Text="端口详情：未选择" />
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.6*" MinWidth="360" />
                <ColumnDefinition Width="4" />
                <ColumnDefinition Width="*" MinWidth="320" />
            </Grid.ColumnDefinitions>

            <Grid Margin="0,0,12,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="4" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <GroupBox Header="串口接收区域" Margin="0,0,0,8">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <DockPanel Grid.Row="0" Margin="0,0,0,8">
                            <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                                <TextBlock Margin="4,0"
                                           VerticalAlignment="Center"
                                           FontWeight="SemiBold"
                                           Text="显示编码" />
                                <ComboBox x:Name="ReceiveModeComboBox" Width="120" SelectionChanged="ReceiveModeComboBox_SelectionChanged">
                                    <ComboBoxItem Content="ABC" IsSelected="True" />
                                    <ComboBoxItem Content="HEX" />
                                </ComboBox>
                                <CheckBox x:Name="EnableLcdDecodeCheckBox"
                                          Margin="12,0,0,0"
                                          IsChecked="False"
                                          VerticalAlignment="Center"
                                          Content="启用LCD帧解析"
                                          Checked="EnableLcdDecodeCheckBox_Changed"
                                          Unchecked="EnableLcdDecodeCheckBox_Changed" />
                            </StackPanel>

                            <Button DockPanel.Dock="Right"
                                    HorizontalAlignment="Right"
                                    Content="清空接收"
                                    Background="#64748B"
                                    Click="ClearReceiveButton_Click" />
                        </DockPanel>

                        <RichTextBox x:Name="ReceiveRichTextBox"
                                     Grid.Row="1"
                                     IsReadOnly="True"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Auto"
                                     FontFamily="Consolas"
                                     FontSize="13" />
                    </Grid>
                </GroupBox>

                <GridSplitter Grid.Row="1"
                              Style="{StaticResource SoftGridSplitterStyle}"
                              Height="4"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Center"
                              ResizeBehavior="PreviousAndNext" />

                <GroupBox Grid.Row="2" Header="串口发送区域" Margin="0,8,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Grid.Row="0">
                        <TextBlock Margin="4,0"
                                   VerticalAlignment="Center"
                                   FontWeight="SemiBold"
                                   Text="发送编码" />
                        <ComboBox x:Name="SendModeComboBox" Width="120">
                            <ComboBoxItem Content="ABC" IsSelected="True" />
                            <ComboBoxItem Content="HEX" />
                        </ComboBox>
                    </StackPanel>

                    <TextBox x:Name="SendTextBox"
                             Grid.Row="1"
                             Margin="4"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             FontFamily="Consolas"
                             FontSize="13" />

                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="8,6,8,4" VerticalAlignment="Center">
                        <TextBlock Margin="0,0,8,0" VerticalAlignment="Center" FontWeight="SemiBold" Text="发送结束符" />
                        <ComboBox x:Name="LineEndingComboBox" Width="140">
                            <ComboBoxItem Content="无" IsSelected="True" />
                            <ComboBoxItem Content="\r" />
                            <ComboBoxItem Content="\n" />
                            <ComboBoxItem Content="\r\n" />
                        </ComboBox>
                    </StackPanel>

                    <Grid Grid.Row="3" Margin="4,2,4,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="SelectedFileTextBox"
                                 IsReadOnly="True"
                                 Margin="0,0,6,0"
                                 ToolTip="后续拓展可直接使用该已选文件" />
                        <Button Grid.Column="1"
                                Content="打开文件"
                                Background="#0EA5A4"
                                Click="SelectFileButton_Click" />
                    </Grid>

                    <StackPanel Grid.Row="4"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right">
                        <Button Content="发送文本/命令" Click="SendButton_Click" />
                        <Button Content="发送文件" Background="#00A870" Click="SendFileButton_Click" />
                    </StackPanel>
                </Grid>
            </GroupBox>

            </Grid>

            <GridSplitter Grid.Column="1"
                          Style="{StaticResource SoftGridSplitterStyle}"
                          Width="4"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          ResizeBehavior="PreviousAndNext" />

            <Grid Grid.Column="2" Margin="12,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition x:Name="ReceiveAreaRow" Height="0" />
                    <RowDefinition x:Name="LcdSplitterRow" Height="0" />
                    <RowDefinition x:Name="LcdAreaRow" Height="*" />
                </Grid.RowDefinitions>

                <GroupBox x:Name="LcdPreviewGroupBox" Grid.Row="2" Header="LCD 预览 (RGB565 + Tail: 0D 00 07 21)">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Border Margin="4"
                                CornerRadius="8"
                                BorderBrush="#475569"
                                BorderThickness="1"
                                Background="#020617">
                            <Viewbox Stretch="Uniform" Margin="10">
                                <Image x:Name="LcdPreviewImage"
                                       Width="208"
                                       Height="104"
                                       Stretch="Fill"
                                       SnapsToDevicePixels="True" />
                            </Viewbox>
                        </Border>

                        <DockPanel Grid.Row="1" Margin="6,6,6,2">
                            <TextBlock x:Name="LcdFrameInfoTextBlock"
                                       DockPanel.Dock="Left"
                                       Text="LCD帧：0"
                                       Foreground="#93C5FD"
                                       FontWeight="SemiBold" />

                            <TextBlock x:Name="LcdSpeedTextBlock"
                                       DockPanel.Dock="Right"
                                       Text="速率：0.0 KB/s"
                                       Foreground="#F8FAFC"
                                       FontWeight="SemiBold" />
                        </DockPanel>
                    </Grid>
                </GroupBox>
            </Grid>
        </Grid>

        <Border Grid.Row="2"
                Padding="10"
                CornerRadius="8"
                BorderBrush="{DynamicResource PanelBorderBrush}"
                BorderThickness="1"
                Background="{StaticResource PanelBackgroundBrush}">
            <TextBlock x:Name="StatusTextBlock"
                       FontWeight="SemiBold"
                       Text="状态：未连接"
                       Foreground="#93C5FD" />
        </Border>
    </Grid>
</Window>
